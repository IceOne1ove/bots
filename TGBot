import requests
from telegram import Update
from telegram.ext import Application, CommandHandler, MessageHandler, filters, ContextTypes

TG_TOKEN=""

URL="https://openrouter.ai/api/v1/chat/completions"

API_KEY=""
MODEL = "openrouter/free"

system_prompt="Ты дружелюбный и уважающий людей помощник. Отвечай кратко и по делу."
user_histories={}

chat_history={}
state={}

MAX_MESSAGE_LENGTH=4000

def ask_ai(peer_id:int, message: str)-> str:
    history=chat_history.setdefault(peer_id,[])
    history.append({"role":"user","content":message})
    try:
        response = requests.post(
            URL, headers={
                "Authorization":f"Bearer {API_KEY}", 
                "Content-Type":"application/json"
            },json={
                "model":MODEL,
                "messages":[
                    {"role":"system", "content":system_prompt},
                    *history
                ],
            },
            timeout=60
        )
        data=response.json()
    except requests.RequestException as e:
        history.pop()
        return f"Ошибка соединения: {e}"
        
    if response.status_code !=200 or "choices" not in data or len(data["choices"])==0:
        history.pop()
        error_msg=data.get("error",{})
        if isinstance(error_msg,dict):
            msg=error_msg.get("message","Ошибка")
        else:
            msg=str(error_msg) if error_msg else"ошибка"
        return f"Ошибка: {msg}"

    try:
        answer=data["choices"][0]["message"]["content"]
    except (KeyError,IndexError,TypeError):
        history.pop()
        return "Ошибка при разборе ответа ИИ"

    if not answer:
        history.pop()
        return "Пустой ответ от ИИ"

    history.append({"role":"asssistant","content": answer})
    if len(history)>10:
        chat_history[peer_id]=history[-10:]

    return answer

def reset_dialog(peer_id):
    chat_history.pop(peer_id,None)
    state.pop(peer_id,None)

print("Бот запущен. Ожидаю сообщениия...")

async def send_long_message(update: Update, text: str)->None:
    if not text:
        return

    for i in range(0, len(text), MAX_MESSAGE_LENGTH):
        chunk=text[i:i+ MAX_MESSAGE_LENGTH]
        await update.message.reply_text(chunk)

async def start_command(update:Update, context:ContextTypes.DEFAULT_TYPE)->None:
    await update.message.reply_text(
        "Привет я твой напарник. Расскажи о каком животном ты хотел бы узнать."
    )
    reset_dialog(update.effective_chat.id)


async def reset_command(update:Update, context:ContextTypes.DEFAULT_TYPE)-> None:
    reset_dialog(update.effective_chat.id)
    await update.message.reply_text("Диалог сброшеню Начинаем заново.")

async def handle_message(update:Update,context:ContextTypes.DEFAULT_TYPE)->None:
    text=update.message.text.strip()
    if not text:
        return

    peer_id=update.effective_chat.id

    if text.lower().startswith("/reset"):
        reset_dialog(peer_id)
        await update.message.reply_text("Диалог сброшен.")
        return

    await update.message.chat.send_action(action="typing")
    ai_response=ask_ai(peer_id, text)
    await send_long_message(update,ai_response)

def main()->None:
    application=Application.builder().token().BUILD()

    application.add_handler(CommandHandler[DEFAULT_TYPE, Any]("start", start_command))
    application.add_handler(CommandHandler[DEFAULT_TYPE, Any]("reset",  reset_command))
    application.add_handler(MessageHandler[DEFAULT_TYPE, Any](filters.TEXT & filters.COMMAND, handle_message))

    print("Бот запущен. Ожидаю сообщения...")
    application.run_polling(allowed_updates=Update.ALL_TYPES)


if__name__=="__main__":
    main(
