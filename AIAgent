from email import message
import requests
import vk_api
import random
from vk_api.bot_longpoll import VkBotLongPoll, VkBotEventType

VK_TOKEN=""
GROUP_ID=

vk_session=vk_api.VkApi(token=VK_TOKEN)
vk=vk_session.get_api()
longpoll=VkBotLongPoll(vk_session, GROUP_ID)

API_KEY=""
URL="https://openrouter.ai/api/v1/chat/completions"
MODEL = "openrouter/free"

system_prompt="Ты дружелюбный и уважающий людей помощник. Отвечай кратко и по делу."
user_message=input("Задай вопрос ИИ и дождись ответа.")
user_histories={}

chat_history={}
state={}

MAX_VK_MESSAGE_LENGTH=4000

def send_message(user_id, text):
    if not text:
        return
    if len(text)<=MAX_VK_MESSAGE_LENGTH:
        vk.messages.send(
            user_id=user_id,
            message=text,
            random_id=random.randint(1,2**31-1)
        )
        return
    for i in range(0,len(text), MAX_VK_MESSAGE_LENGTH):
        chunk=text[i:i+MAX_VK_MESSAGE_LENGTH]
        vk.messages.send(
            user_id=user_id,
            message=chunk,
            random_id=random.randint(1,2**31-1)
        )
def ask_ai(user_id, message):
    history=chat_history.setdefault(user_id,[])
    history.append({"role":"user","content":message})
    try:
        response = requests.post(
            URL, headers={
                "Authorization":f"Bearer {API_KEY}", 
                "Content-Type":"application/json"
            },json={
                "model":MODEL,
                "messages":[
                    {"role":"system", "content":system_prompt},
                    *history
                ],
            },
            timeout=60
        )
        data=response.json()
    except requests.RequestException as e:
        history.pop()
        return f"Ошибка соединения: {e}"
        
    if response.status_code !=200 or "choices" not in data or len(data["choices"])==0:
        history.pop()
        error_msg=data.get("error",{})
        if isinstance(error_msg,dict):
            msg=error_msg.get("message","Ошибка")
        else:
            msg=str(error_msg) if error_msg else"ошибка"
            return f"Ошибка: {msg}"

    try:
        answer=data["choices"][0]["message"]["content"]
    except (KeyError,IndexError,TypeError):
        history.pop()
        return "Ошибка при разборе ответа ИИ"

    if not answer:
        history.pop()
        return "Пустой ответ от ИИ"

    history.append({"role":"asssistant","content": answer})
    if len(history)>10:
        chat_history[user_id]=history[-10:]

    return answer

def reset_dialog(user_id):
    chat_history.pop(user_id,None)
    state.pop(user_id,None)

print("Бот запущен. Ожидаю сообщениия...")

for event in longpoll.listen():
    if event.type==VkBotEventType.MESSAGE_NEW:
        msg=event.obj.message
        user_id=msg["user_id"]
        text=msg["text"].strip()

        if not text:
            continue
        if text.lower().startswith("/reset"):
            reset_dialog(user_id)
            send_message(user_id, "Диалог сброшен.")
            continue

        answer=ask_ai(user_id,text)
        send_message(user_id,answer)
